<!DOCTYPE html>
    <html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Latihan 1 - HTML5</title>
</head>
<body>
<header>
    <h1>Selamat Datang</h1>
    <p>Belajar elemen semantik HTML5</p>
</header>
<nav>
    <a href="#tentang">Tentang</a> |
    <a href="#kursus">Kursus</a> |
    <a href="#kontak">Kontak</a>
</nav>

<section id="tentang">
    <h2>Tentang Halaman Ini</h2>
    <p>Ini merupakan tempat masuk untuk mendaftar ke kursus belajar</p>
</section>

<section id="kursus">
<h2>Daftar Kursus</h2>
    <table border="1">
    <tr>
        <th>No</th>
        <th>Nama Kursus</th>
        <th>Durasi</th>
    </tr>
    <tr>
     <td>1</td>
        <td>Dasar HTML & CSS</td>
        <td>4 Minggu</td>
    </tr>
    <tr>
        <td>2</td>
        <td>JavaScript Fundamental</td>
        <td>6 Minggu</td>
    </tr>
    </table>
</section>

<section id="kontak">
    <h2> Hubungi kami </h2>
    <label>Nama :</label>
    <input required>
    <p></p>
    <label>Email :</label>
    <input required>
    <p></p>
    <label>Pesan :</label>
    <textarea name="pesan"></textarea>
</section>

<section id="choose">
<h2>Pilih jurusan yang ingin dipelajari</h2>

<form>
  <form>
  <input type="radio" id="html" name="jurusan" value="HTML">
  <label for="html">HTML</label><br>
  <input type="radio" id="javascript" name="jurusan" value="JavaScript">
  <label for="javascript">JavaScript</label>
</form> 

</section>

<section id="file">
    <h2>Masukin video pengenalan diri</h2>
    <form >
    <label for="file">File</label>
    <input id="file" name="file" type="file" />
</form>
</section>

<section id="waktu">
    <h2>Masukan jam berapa mengisi form ini</h2>
<form>
  <label for="appt">Pilih jam : </label>
  <input type="time" id="appt" name="appt">
</form>
</section>

<section id="tanggal">
    <h2>Masukkan tanggal masuk </h2>
    <form>
        <label for="tanggal" > Tanggal : </label>
        <input type="date" id="tanggal" name="tanggal">
    </form>
</section>

<section id="quest">
    <h2>Pilih kursus</h2>
    <input type="checkbox" id="html">
    <label for="html">Kursus HTML & CSS</label>
    <p></p>
    <input type="checkbox" id="javascript">
    <label for="javascript">Kursus Javascript</label>
</section>


<section id="email">
    <h2>Masukkan email :</h2>
    <form>
        <label for="email">Email :</label>
        <input type="email" id="email" name="email">
    </form>
</section>

<section id="warna">
    <h2>Pilih warna favorit</h2>
    <form>
    <label for="image">Pilih warna favorit anda : </label>
    <input type="color" name="warna" id="warna">
    </form>
</section>

<section id="number">
    <h2>Umur</h2>
    <form>
    <label for="number">Umur :</label>
    <input type="number" id="number" name="number">
    </form>
</section>

<section id="waktu">
    <h2>Waktu ketemuan</h2>
    <form>
    <label for="waktu">jam :</label>
    <input type="datetime-local" id="waktu" name="waktu">
    </form>
</section>

<section id="sesi">
    <h2>Tentukan sesi</h2>
    <label for="sesi">Pilih sesi kursus (sesi 1 sampai 6)</label>
    <input type="range" id="sesi" name="sesi">
</section>

<input type="submit" name="submit" id="submit">
<footer>
    <p>&copy; 2025 oleh Defrio Andersen. </p>
</footer>
</body>
</html>
